{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext"],
    "strict": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "paths": {
      "@litter/shared": ["./packages/shared/src/index.ts"],
      "@litter/runtime": ["./packages/runtime/src/index.ts"],
      "@litter/nitro": ["./packages/nitro/src/index.ts"],
      "@litter/ui": ["./packages/ui/src/index.ts"],
      "@litter/transcript": ["./packages/transcript/src/index.d.ts"]
    }
  }
}
