{
  "name": "pounce-bridge-app",
  "private": true,
  "version": "1.0.6",
  "type": "module",
  "description": "Pounce — a tiny double-click desktop app that runs the bridge and shows a pairing QR.",
  "scripts": {
    "sync-server": "mkdir -p server && bun build ../apps/bridge/server.mjs --target=node --outfile server/server.mjs",
    "dev": "bun run sync-server && electrobun dev",
    "build": "bun run sync-server && electrobun build"
  },
  "dependencies": {
    "electrobun": "^1.0.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0"
  }
}
